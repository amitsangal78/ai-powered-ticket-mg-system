# Optional overrides for `docker compose` (copy to `.env` at repo root).
# Never commit real production secrets.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tickets
POSTGRES_PORT=5432
API_PORT=3000

# Must be ≥ 32 characters (backend Zod env validation)
JWT_SECRET=local-dev-jwt-secret-min-32-characters!!

# Browser origin allowed by CORS (Vite default)
FRONTEND_ORIGIN=http://localhost:5173
